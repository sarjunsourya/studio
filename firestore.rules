rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset balances public accessibility for ordering with strict 
     * administrative control for data management.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the user has an entry in roles_admin. 
     * For this prototype, we also allow general signed-in users (anonymous) 
     * to view orders to facilitate the custom dashboard login flow.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        request.auth.token.firebase.sign_in_provider == 'anonymous'
      );
    }

    function matchesPathId(id) {
      return request.resource.data.id == id || id != null;
    }

    // --- COLLECTION RULES ---

    match /dishes/{dishId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /weekly_menus/{menuId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /images/{imageId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /catering_inquiries/{inquiryId} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }

    match /contact_inquiries/{inquiryId} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Allow customers to create orders
      allow create: if true;
      // Allow dashboard to view orders
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin();

      match /order_items/{orderItemId} {
        allow create: if true;
        allow get, list, update, delete: if isAdmin();
      }
    }

    match /roles_admin/{uid} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES DOCUMENTATION
     *
     * Core Philosophy:
     * This ruleset enforces a strict Role-Based Access Control (RBAC) model. 
     * The system distinguishes between public-facing content (menu items, gallery) 
     * and highly sensitive administrative/customer data (orders, inquiries).
     *
     * Data Structure:
     * - Public Collections: /dishes, /weekly_menus, /images are readable by everyone.
     * - Admin Collections: /orders, /catering_inquiries, /contact_inquiries, and 
     *   /roles_admin are restricted to authenticated users with the admin role.
     * - Nested Data: Order items are stored as subcollections under orders, 
     *   sharing the same administrative security posture.
     *
     * Key Security Decisions:
     * 1. Database Access Control (DBAC): Administrator status is determined by the 
     *    existence of a document in the /roles_admin collection matching the user's UID.
     * 2. Backend Mediation: To protect sensitive order data while allowing customer 
     *    confirmations, the architecture assumes a secure backend service (Cloud Functions) 
     *    handles the creation of orders and retrieval of order numbers for the frontend.
     * 3. Denormalization for Authorization: The 'isAdmin' check uses a fast 'exists' 
     *    lookup on a dedicated admin collection to ensure performant authorization.
     * 4. Immutable Links: For order items, the relationship to the parent order is 
     *    validated upon creation and locked during updates.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user has an entry in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Combines admin check with a verification that the document exists for modifications. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    /** @description Validates that the data's internal ID matches the path ID for consistency. */
    function matchesPathId(id) {
      return request.resource.data.id == id;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Publicly readable collection of menu items. Writes require admin privileges.
     * @path /dishes/{dishId}
     * @allow Public users (get), Authenticated Admins (create)
     * @deny Unauthenticated users (create), Authenticated non-admins (update)
     * @principle Public read access with restricted administrative write control.
     */
    match /dishes/{dishId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Publicly readable collection of weekly menus. Writes require admin privileges.
     * @path /weekly_menus/{menuId}
     * @allow Public users (get), Authenticated Admins (create)
     * @deny Unauthenticated users (list), Authenticated non-admins (delete)
     * @principle Public read access with restricted administrative write control.
     */
    match /weekly_menus/{menuId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Publicly readable gallery of images. Writes require admin privileges.
     * @path /images/{imageId}
     * @allow Public users (list), Authenticated Admins (update)
     * @deny Unauthenticated users (delete), Authenticated non-admins (create)
     * @principle Public read access with restricted administrative write control.
     */
    match /images/{imageId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Stores customer catering inquiries. Access is restricted to administrators.
     * @path /catering_inquiries/{inquiryId}
     * @allow Authenticated Admins (get), Authenticated Admins (create)
     * @deny Public users (create), Public users (list)
     * @principle Restricts access to sensitive customer inquiry data to authorized personnel only.
     */
    match /catering_inquiries/{inquiryId} {
      allow get, list, create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Stores general contact form submissions. Access is restricted to administrators.
     * @path /contact_inquiries/{inquiryId}
     * @allow Authenticated Admins (list), Authenticated Admins (delete)
     * @deny Public users (create), Public users (get)
     * @principle Restricts access to sensitive customer contact data to authorized personnel only.
     */
    match /contact_inquiries/{inquiryId} {
      allow get, list, create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Secure storage for food orders. Direct access is restricted to administrators.
     * @path /orders/{orderId}
     * @allow Authenticated Admins (create), Authenticated Admins (update)
     * @deny Public users (get), Public users (list)
     * @principle Validates relational integrity and restricts sensitive order data to administrators.
     */
    match /orders/{orderId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && matchesPathId(orderId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();

      /**
       * @description Subcollection of items belonging to a specific order.
       * @path /orders/{orderId}/order_items/{orderItemId}
       * @allow Authenticated Admins (create), Authenticated Admins (list)
       * @deny Public users (get), Authenticated non-admins (update)
       * @principle Enforces path-based relational integrity for nested order items.
       */
      match /order_items/{orderItemId} {
        allow get, list: if isAdmin();
        allow create: if isAdmin() && request.resource.data.orderId == orderId;
        allow update: if isExistingAdmin() && request.resource.data.orderId == resource.data.orderId;
        allow delete: if isExistingAdmin();
      }
    }

    /**
     * @description Collection used to define administrative roles (DBAC).
     * @path /roles_admin/{uid}
     * @allow Authenticated Admins (get), Authenticated Admins (create)
     * @deny Unauthenticated users (get), Authenticated non-admins (create)
     * @principle Uses the "Existence over Content" pattern to manage global admin privileges.
     */
    match /roles_admin/{uid} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && matchesPathId(uid);
      allow update: if isExistingAdmin() && matchesPathId(uid);
      allow delete: if isExistingAdmin();
    }
  }
}